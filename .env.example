# API environment: "staging" or "live"
# Leave unset for local dev (defaults to staging)
VITE_API_ENV=staging

# Google Maps JS API key for the public event "Map Explorer".
# Enable BOTH "Maps JavaScript API" and "Places API" on the key, and
# restrict it by HTTP referrer. When unset, the explorer falls back to a
# placeholder. Exposed to the client via `envPrefix` in vite.config.ts.
GOOGLE_MAPS_API_KEY=

# Stripe publishable key for the Shop checkout card field (pk_test_… / pk_live_…).
# Exposed to the client via Vite's default VITE_ prefix. When unset, checkout
# shows a "payments unavailable" notice.
VITE_STRIPE_PUBLISHABLE_KEY=
